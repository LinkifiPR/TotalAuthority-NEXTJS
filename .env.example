# Copy to .env.local for local development
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-5.4
OPENROUTER_RUNTIME_MODEL=openai/gpt-4.1-mini
OPENROUTER_FALLBACK_MODEL=openai/gpt-4.1-mini
AI_SETUP_JOB_SECRET=replace_with_random_secret

# Existing app variables (fill as needed)
NEXT_PUBLIC_SITE_URL=https://totalauthority.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
